# Pramana Engine - Environment Configuration Template
# Copy this file to .env and fill in your values.
# Docker Compose reads .env automatically.

# --- Admin token for /api/rag/cache/clear ---
# If set: all requests to that endpoint MUST supply header X-Pramana-Admin-Token: <value>
# If empty: endpoint is localhost-only (127.0.0.1 / ::1) — already enforced in web.py
PRAMANA_ADMIN_TOKEN=pramana2026


# --- OpenAI fallback (optional) ---
# If set AND Ollama is unavailable, the engine falls back to gpt-4o-mini automatically.
OPENAI_API_KEY=

# --- Ollama host ---
# Default for local use: http://localhost:11434
# For Docker Compose: set to http://ollama:11434 (handled automatically by docker-compose.yml)
OLLAMA_HOST=http://localhost:11434
